{
    "files.autoSave": "afterDelay",
    "window.zoomPerWindow": false,
    "editor.codeActions.triggerOnFocusChange": true,
    "editor.fontFamily": "'Fira Code Retina', 'monospace', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 18,
    "editor.suggest.insertMode": "insert",
    "workbench.editor.enablePreview": false,
    "editor.renderWhitespace": "none",
    "editor.trimAutoWhitespace": false,
    "files.insertFinalNewline": true,
    "editor.renderFinalNewline": "on",
    "editor.scrollBeyondLastLine": false,
    "workbench.startupEditor": "none",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.initialHint": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "editor.insertSpaces": true,
    "editor.useTabStops": false,
    "sonarlint.disableTelemetry": true,
    "raspberry-pi-pico.python3Path": "/bin/python",
    "sonarlint.rules": {},
    "editor.tabSize": 4,
    "editor.indentSize": 4,
    "tinymist.formatterIndentSize": 4,
    "tinymist.exportPdf": "onSave",
    "tinymist.lint.when": "onSave",
    "tinymist.lint.enabled": true,
    "tinymist.preview.scrollSync": "onSelectionChange",
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "[typst]": {
        "editor.tabSize": 4,
        "editor.indentSize": 4,
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[json]": {
        "editor.quickSuggestions": {
            "strings": true,
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.indentSize": 4,
        "editor.tabSize": 4,
    },
    "[yaml]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4,
        "editor.autoIndent": "advanced",
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.quickSuggestions": {
            "strings": "on",
        },
    },
    "[markdown]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off",
        },
        "cSpell.fixSpellingWithRenameProvider": true,
        "cSpell.advanced.feature.useReferenceProviderWithRename": true,
        "cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "editor.codeActionsOnSave": {
        "source.fixAll.markdownlint": "always",
        "source.fixAll.prettier": "always",
        "source.fixAll.biome": "always",
    },
    "chat.agent.enabled": false,
    "chat.disableAIFeatures": true,
    "settingsSync.ignoredSettings": ["editor.fontSize", "-window.zoomLevel"],
    "workbench.colorTheme": "Dark Orange Default",
    "Lua.codeLens.enable": true,
    "Lua.completion.keywordSnippet": "Disable",
    "Lua.completion.maxSuggestCount": 0,
    "Lua.hint.arrayIndex": "Enable",
    "Lua.runtime.version": "Lua 5.5",
    "Lua.completion.showWord": "Disable",
    "editor.wordWrap": "on",
    "cSpell.userWords": ["anthro", "behaviour", "forall", "gpio", "pagebreak"],
    "telemetry.editStats.enabled": false,
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "cortex-debug.enableTelemetry": false,
    "cSpell.language": "en-GB,en-US,de-DE",
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://biomejs.dev": true,
    },
    "git.confirmSync": false,
    "evenBetterToml.formatter.arrayTrailingComma": true,
    "prettier.trailingComma": "all",
    "prettier.tabWidth": 4,
    "prettier.semi": true,
    "prettier.printWidth": 120,
    "window.zoomLevel": 2,
}
